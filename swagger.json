{
  "openapi": "3.0.0",
  "info": {
    "title": "Pi-Zzaria API",
    "version": "1.0.0",
    "description": "API para sistema de comercialização de pizzas"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["user", "admin"],
            "default": "user"
          }
        }
      },
      "Pizza": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "image": {
            "type": "string"
          },
          "available": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pizza": {
                  "type": "string"
                },
                "quantity": {
                  "type": "number"
                },
                "price": {
                  "type": "number"
                }
              }
            }
          },
          "total": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "preparing", "ready", "delivered", "cancelled"],
            "default": "pending"
          },
          "deliveryAddress": {
            "type": "object",
            "properties": {
              "street": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "zipCode": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/users/register": {
      "post": {
        "summary": "Registrar um novo usuário",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário registrado com sucesso"
          },
          "400": {
            "description": "Erro na requisição"
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Fazer login",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso"
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/api/users/profile": {
      "get": {
        "summary": "Obter perfil do usuário",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil do usuário"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "put": {
        "summary": "Atualizar perfil do usuário",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Perfil atualizado"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "delete": {
        "summary": "Deletar conta do usuário",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Conta deletada"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/api/pizzas": {
      "get": {
        "summary": "Obter todas as pizzas",
        "tags": ["Pizzas"],
        "responses": {
          "200": {
            "description": "Lista de pizzas"
          }
        }
      },
      "post": {
        "summary": "Criar uma nova pizza",
        "tags": ["Pizzas"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pizza"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pizza criada"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/api/pizzas/{id}": {
      "get": {
        "summary": "Obter pizza por ID",
        "tags": ["Pizzas"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pizza encontrada"
          },
          "404": {
            "description": "Pizza não encontrada"
          }
        }
      },
      "put": {
        "summary": "Atualizar pizza",
        "tags": ["Pizzas"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pizza"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pizza atualizada"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Pizza não encontrada"
          }
        }
      },
      "delete": {
        "summary": "Deletar pizza",
        "tags": ["Pizzas"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pizza deletada"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Pizza não encontrada"
          }
        }
      }
    },
    "/api/orders": {
      "get": {
        "summary": "Obter todos os pedidos (admin)",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de todos os pedidos"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "summary": "Criar um novo pedido",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "pizza": {
                          "type": "string"
                        },
                        "quantity": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "deliveryAddress": {
                    "$ref": "#/components/schemas/Order/properties/deliveryAddress"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pedido criado"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/api/orders/my": {
      "get": {
        "summary": "Obter pedidos do usuário",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de pedidos"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/api/orders/{id}": {
      "get": {
        "summary": "Obter pedido por ID",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido encontrado"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Pedido não encontrado"
          }
        }
      },
      "delete": {
        "summary": "Deletar pedido",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido deletado"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Pedido não encontrado"
          }
        }
      }
    },
    "/api/orders/{id}/status": {
      "put": {
        "summary": "Atualizar status do pedido",
        "tags": ["Orders"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["pending", "preparing", "ready", "delivered", "cancelled"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status atualizado"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Pedido não encontrado"
          }
        }
      }
    }
  }
}